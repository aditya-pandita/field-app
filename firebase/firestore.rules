rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /profiles/{userId} {
      allow read, update: if request.auth.uid == userId;
      allow create: if request.auth.uid == userId;
    }
    match /sessions/{id} {
      allow read, write: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }
    match /approaches/{id} {
      allow read, write: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }
    match /scenarioSessions/{id} {
      allow read, write: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      match /messages/{m}  { allow read, write: if request.auth != null; }
      match /feedback/{f}  { allow read, write: if request.auth != null; }
    }
    match /adversarySessions/{id} {
      allow read, write: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      match /messages/{m} { allow read, write: if request.auth != null; }
      match /debrief/{d}  { allow read, write: if request.auth != null; }
    }
    match /trainerSessions/{id} {
      allow read, write: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      match /pivots/{p} { allow read, write: if request.auth != null; }
    }
    match /flashcardProgress/{id} {
      allow read, write: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }
    match /coaches/{id}            { allow read: if true; allow write: if false; }
    match /topicBank/{id}          { allow read: if true; allow write: if false; }
    match /transitionPhrases/{id}  { allow read: if true; allow write: if false; }
    match /flashcardTemplates/{id} { allow read: if true; allow write: if false; }
  }
}